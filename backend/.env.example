# Get your key from https://aistudio.google.com/apikey
# Current Gemini API keys from AI Studio are "Auth keys" and start with
# "AQ.Ab..." (this replaced the older "AIza..." Standard key format in 2026).
# Either format works with this backend, since it uses the native
# generativelanguage.googleapis.com endpoint via the official SDK.
GEMINI_API_KEY=AQ.your_key_here
GEMINI_MODEL=gemini-2.0-flash
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000
BATCH_SIZE=20
MAX_RETRIES=3
